NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb://localhost:27017/camp

JWT_ACCESS_SECRET=your_access_secret_change_this
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CLIENT_URL=http://localhost:5173

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (gửi OTP quên mật khẩu). Ví dụ Gmail: dùng App Password nếu bật 2FA
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS="xxxx xxxx xxxx xxxx"
# MAIL_FROM=your@gmail.com
