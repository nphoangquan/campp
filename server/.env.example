# ============================================================
# .env.example — Mẫu biến môi trường cho server
# Copy thành .env và điền giá trị thật trước khi chạy
# ============================================================

NODE_ENV=development
PORT=5000

# MongoDB — đổi thành connection string thật (Atlas hoặc local)
MONGODB_URI=mongodb://localhost:27017/campp

# JWT — đổi thành chuỗi ngẫu nhiên, đủ dài, bảo mật
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Client URL — URL frontend (dùng cho CORS)
CLIENT_URL=http://localhost:5173

# Cloudinary — để trống nếu chưa cần upload (tuỳ chọn)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# Email SMTP — để trống nếu chưa cần gửi mail (tuỳ chọn)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_SECURE=
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=
