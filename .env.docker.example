# ============================================================
# .env.docker.example — Template biến môi trường cho Docker
#
# Cách dùng:
#   cp .env.docker.example .env.docker
#   Chỉnh giá trị thật trong .env.docker (KHÔNG commit file này)
#
# Development:  docker-compose up --build
# Production:   docker-compose -f docker-compose.yml -f docker-compose.prod.yml up
# ============================================================

# ---- Backend ----
NODE_ENV=production
PORT=5000

# MongoDB — local Docker (dev) hoặc Atlas URI (production)
# Dev:        mongodb://mongo:27017/campp
# Production: mongodb+srv://<user>:<pass>@cluster.mongodb.net/campp
MONGODB_URI=mongodb://mongo:27017/campp

# JWT — tạo chuỗi ngẫu nhiên đủ dài, ví dụ:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_STRONG_RANDOM_SECRET_64_CHARS
JWT_REFRESH_SECRET=CHANGE_ME_ANOTHER_STRONG_RANDOM_SECRET_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# URL frontend (cho CORS + Socket.IO)
# Dev:        http://localhost:3000
# Production: https://yourdomain.com
CLIENT_URL=http://localhost:3000

# ---- Cloudinary (tuỳ chọn — để trống nếu chưa dùng upload) ----
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- SMTP Email (tuỳ chọn — để trống nếu chưa dùng OTP) ----
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ---- Frontend build args ----
# /api → nginx proxy sang backend (cùng domain)
# Production subdomain riêng: https://api.yourdomain.com/api
VITE_API_URL=/api
# Socket.IO URL — trình duyệt kết nối trực tiếp
# Dev:        http://localhost:5000
# Production: https://api.yourdomain.com (hoặc wss:// nếu qua proxy)
VITE_SOCKET_URL=http://localhost:5000
